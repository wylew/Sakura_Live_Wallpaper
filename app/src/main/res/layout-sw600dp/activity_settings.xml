<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sakura_pink_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sakura_pink_light"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextColor="@color/sakura_text_dark" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Settings Column (Left) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- Petal Count -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_petal_count"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_petal_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Wind Strength -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_wind_strength"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_wind_strength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Petal Size -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_petal_size"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_petal_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Fall Speed -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_fall_speed"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_fall_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Rotation Speed -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_rotation_speed"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_rotation_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Petal Color -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_petal_color"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_petal_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <!-- Transparency -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_transparency"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/sakura_text_dark"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_transparency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark"
                    app:trackColorInactive="@color/sakura_pink_medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_background"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/pref_background_image"
                    app:backgroundTint="@color/sakura_pink_medium"
                    app:cornerRadius="28dp"
                    android:textColor="@color/sakura_text_dark" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_collect_at_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="48dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/pref_collect_at_bottom"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="@color/sakura_text_dark" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_set_wallpaper"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="64dp"
                    android:text="Set Wallpaper"
                    app:backgroundTint="@color/sakura_green"
                    app:cornerRadius="36dp"
                    android:textSize="20sp"
                    android:textColor="@color/sakura_white" />
            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Preview Column (Right) -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <com.wylew.sakuralivewallpaper.WallpaperPreviewView
                    android:id="@+id/wallpaper_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#222" />

            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
