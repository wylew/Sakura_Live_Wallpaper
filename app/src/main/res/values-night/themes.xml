<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SakuraLiveWallpaper" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/sakura_pink_medium</item>
        <item name="colorPrimaryVariant">@color/sakura_pink_dark</item>
        <item name="colorOnPrimary">@color/sakura_text_dark</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/sakura_green</item>
        <item name="colorSecondaryVariant">@color/sakura_green</item>
        <item name="colorOnSecondary">@color/sakura_white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/sakura_pink_light</item>
        <item name="android:windowBackground">@color/sakura_pink_light</item>
        <!-- Custom UI element colors -->
        <item name="android:textColor">@color/sakura_text_dark</item>
        <item name="android:textColorSecondary">@color/sakura_text_dark</item>
    </style>
</resources>