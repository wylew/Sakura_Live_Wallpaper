<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Standard Android Adaptive Icon (108dp x 108dp)
      Original "Safe Area" was 72dp.
      Reducing size by another 25% (72dp * 0.75 = 54dp).
      This ensures the flower is comfortably centered and well within all potential
      system masks (circular, square, squircle) used by different launchers and system settings.
    -->
    <item
        android:drawable="@drawable/sakura"
        android:gravity="center"
        android:width="54dp"
        android:height="54dp" />
</layer-list>