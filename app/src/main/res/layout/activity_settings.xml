<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sakura_pink_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sakura_pink_light"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleCentered="true"
            app:titleTextColor="@color/sakura_text_dark" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.wylew.sakuralivewallpaper.WallpaperPreviewView
                        android:id="@+id/wallpaper_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#222" />

                    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                        android:id="@+id/btn_select_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_margin="16dp"
                        android:text="Select Image"
                        android:textColor="@color/sakura_text_dark"
                        app:backgroundTint="@color/sakura_pink_medium"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconTint="@color/sakura_text_dark"
                        app:elevation="4dp" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Two Column Settings Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp">

                <!-- Column 1 (Left) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_petal_count"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_petal_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_petal_size"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_petal_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_petal_color"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_petal_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />
                </LinearLayout>

                <!-- Column 2 (Right) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:paddingStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_wind_strength"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_wind_strength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_fall_speed"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_fall_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_rotation_speed"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_rotation_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />
                </LinearLayout>
            </GridLayout>

            <!-- Row for Transparency -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_transparency"
                    android:textSize="16sp"
                    android:textColor="@color/sakura_text_dark" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_transparency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:thumbColor="@color/sakura_pink_dark"
                    app:trackColorActive="@color/sakura_pink_dark" />
            </LinearLayout>

            <!-- Collection Settings Section -->
            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/check_collect_at_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_collect_at_bottom"
                android:textSize="16sp"
                android:textColor="@color/sakura_text_dark"
                app:buttonTint="@color/sakura_pink_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="8dp"
                android:text="Settle Probability defines the likelihood a petal will stick to the screen. Settle Area Height controls the percent of the screen petals can settle on, starting from the bottom. Can impact performance."
                android:textSize="12sp"
                android:textColor="@color/sakura_text_dark"
                android:alpha="0.7" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="8dp">

                <!-- Left: Settle Probability -->
                <LinearLayout
                    android:id="@+id/layout_settle_prob"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:paddingEnd="8dp">
                    <TextView
                        android:id="@+id/label_settle_prob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settle Probability"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_settle_probability"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />
                </LinearLayout>

                <!-- Right: Settle Area Height -->
                <LinearLayout
                    android:id="@+id/layout_settle_height"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:paddingStart="8dp">
                    <TextView
                        android:id="@+id/label_settle_height"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settle Area Height"
                        android:textSize="16sp"
                        android:textColor="@color/sakura_text_dark" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_settle_height"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:thumbColor="@color/sakura_pink_dark"
                        app:trackColorActive="@color/sakura_pink_dark" />
                </LinearLayout>
            </GridLayout>

            <!-- Empty space to allow scrolling above FAB -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_set_wallpaper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="16dp"
        android:text="Set Wallpaper"
        android:textColor="@color/sakura_text_dark"
        app:backgroundTint="@color/sakura_green"
        app:icon="@android:drawable/ic_menu_set_as"
        app:iconTint="@color/sakura_text_dark" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
